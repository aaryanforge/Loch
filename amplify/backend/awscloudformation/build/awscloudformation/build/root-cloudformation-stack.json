        "TemplateURL": "https://s3.amazonaws.com/amplify-authamplify-authdev-205452-deployment/amplify-cfn-templates/auth/userPoolGroups-cloudformation-template.json",
        "Parameters": {
          "AuthRoleArn": {
            "Fn::GetAtt": [
              "AuthRole",
              "Arn"
            ]
          },
          "UnauthRoleArn": {
            "Fn::GetAtt": [
              "UnauthRole",
              "Arn"
            ]
          },
          "authAuthAmplifySignInOnlyUserPoolId": {
            "Fn::GetAtt": [
              "authAuthAmplifySignInOnly",
              "Outputs.UserPoolId"
            ]
          },
          "authAuthAmplifySignInOnlyAppClientIDWeb": {
